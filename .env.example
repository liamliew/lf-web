# Supabase project URL — shared with the lf-scan Android app.
# Find it in Supabase dashboard > Project Settings > API.
PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe to expose in the browser bundle.
# Used for all client-side reads/writes, gated by RLS policies.
PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY, never exposed to the client.
# Bypasses RLS. Used in src/lib/supabase-server.ts for admin operations
# (e.g. team member management, audit finalization).
# Never prefix this with PUBLIC_ or import it from client-side code.
SUPABASE_SERVICE_ROLE_KEY=
